# Demo-safe environment template

## Gemini values
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

## App values
LOG_LEVEL=INFO
APP_DEBUG=true
DEBUG_PAYLOAD_LOGS=false
ENABLE_PUBLIC_DEMO=false
CORS_ALLOW_ORIGINS=["*"]

## Store values
STORE_NAME=NEXFIT
ASSISTANT_NAME=PHOENIX
STORE_TAGLINE=Your go-to store for performance sports gear.

## WooCommerce values
WC_STORE_URL=https://store.example.com
WC_CONSUMER_KEY=ck_your_woocommerce_consumer_key_here
WC_CONSUMER_SECRET=cs_your_woocommerce_consumer_secret_here

## RAG / Vector Search values
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
QDRANT_COLLECTION=products
