#  .env file 

## Gemini values
GEMINI_API_KEY= gemini_api_key_here must be set 


GEMINI_MODEL   = gemini-2.5-flash-native-audio-preview-12-2025

## App values
LOG_LEVEL = INFO
APP_DEBUG = true 
DEBUG_PAYLOAD_LOGS = false
ENABLE_PUBLIC_DEMO = false


## WooCommerce values
WC_STORE_URL=https://store.com need to be set for woo commerce integration
WC_CONSUMER_KEY=ck_woocommerce_consumer_key_here
WC_CONSUMER_SECRET=cs_woocommerce_consumer_secret_here


## RAG / Vector Search Vaules
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
QDRANT_COLLECTION=products
